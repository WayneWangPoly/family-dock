rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isMember(familyId) {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/families/$(familyId)/members/$(request.auth.uid));
    }

    function isParent(familyId) {
      return isMember(familyId)
        && firestore.get(/databases/(default)/documents/families/$(familyId)/members/$(request.auth.uid)).data.role in ["parent", "guardian", "owner"];
    }

    match /families/{familyId}/{allPaths=**} {
      allow read: if isMember(familyId);
      allow create, update: if isMember(familyId)
        && request.resource.size < 20 * 1024 * 1024;
      allow delete: if isParent(familyId);
    }
  }
}
