# Family Dock Firebase front-end config
# Copy to .env.local and fill from Firebase Console -> Project settings -> Your apps -> Web app.
# These VITE_ values are public browser config. Do NOT put server secrets here.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional browser key only. Keep server Maps API key inside Cloud Functions secret instead.
VITE_GOOGLE_MAPS_BROWSER_KEY=
