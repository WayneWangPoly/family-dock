# Copy this file to .env.local and fill it with your Firebase Web App config.
# Firebase Console -> Project settings -> General -> Your apps -> Web app config

VITE_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT_ID.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT_ID.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_MESSAGING_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_FIREBASE_APP_ID

# Optional integrations

# Browser key for Google Maps JavaScript API.
# Code reads this exact variable name.
VITE_GOOGLE_MAPS_BROWSER_KEY=

# Web Push public VAPID key.
# Required only if you enable browser/PWA push notifications.
VITE_VAPID_PUBLIC_KEY=
